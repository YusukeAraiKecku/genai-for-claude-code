{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/your-org/genai-for-claude-code/schemas/genai.recipe.schema.json",
  "title": "Genai Recipe",
  "description": "Declarative spec that compiles to a Claude Code Skill package.",
  "type": "object",
  "required": ["id", "name", "version", "description", "execution", "inputs", "outputs"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*[a-z0-9]$",
      "description": "kebab-case identifier; usable as a directory name."
    },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+(-[0-9a-zA-Z.-]+)?$" },
    "description": { "type": "string", "minLength": 20 },
    "tags": { "type": "array", "items": { "type": "string" } },
    "origin": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["original", "clean-room-inspired"] },
        "source_model": { "type": "string" },
        "source_code_copied": { "type": "boolean", "const": false }
      }
    },
    "execution": {
      "type": "object",
      "required": ["default_mode"],
      "additionalProperties": false,
      "properties": {
        "default_mode": { "$ref": "#/$defs/executionMode" },
        "allowed_modes": {
          "type": "array",
          "items": { "$ref": "#/$defs/executionMode" },
          "uniqueItems": true
        },
        "remote_api_required": { "type": "boolean", "default": false }
      }
    },
    "inputs": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/inputField" }
    },
    "local_context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "references": {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "required": ["path"],
                "additionalProperties": false,
                "properties": {
                  "path": { "type": "string" },
                  "description": { "type": "string" },
                  "index": { "type": "boolean" }
                }
              }
            ]
          }
        },
        "templates": {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "required": ["path"],
                "additionalProperties": false,
                "properties": {
                  "path": { "type": "string" },
                  "description": { "type": "string" }
                }
              }
            ]
          }
        },
        "examples": { "type": "array", "items": { "type": "string" } }
      }
    },
    "outputs": {
      "type": "object",
      "required": ["primary"],
      "additionalProperties": false,
      "properties": {
        "primary": { "type": "string", "enum": ["markdown", "text", "json", "yaml"] },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "path"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "path": { "type": "string", "pattern": "^[A-Za-z0-9_./-]+$" },
              "format": { "type": "string", "enum": ["markdown", "text", "json", "yaml"] },
              "required": { "type": "boolean", "default": false },
              "description": { "type": "string" }
            }
          }
        }
      }
    },
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rules": { "type": "array", "items": { "type": "string" } },
        "eval": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "fixture_dir": { "type": "string" },
            "golden_dir": { "type": "string" }
          }
        }
      }
    },
    "security": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "network": { "type": "string", "enum": ["deny-by-default", "explicit-allow"] },
        "secrets": { "type": "string", "enum": ["forbid-hardcoded", "env-only"] },
        "side_effects": { "type": "string", "enum": ["read-only-by-default", "explicit-write"] },
        "pii": { "type": "string", "enum": ["forbid", "masked-only", "declared"] },
        "allowed_tools": { "type": "array", "items": { "type": "string" } },
        "remote_api": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "requires_user_confirmation": { "type": "boolean" },
            "endpoint_env": { "type": "string" },
            "api_key_env": { "type": "string" }
          }
        }
      }
    },
    "claude": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "skill_name": { "type": "string", "pattern": "^[a-z][a-z0-9-]*[a-z0-9]$" },
        "auto_invocation": { "type": "boolean", "default": true },
        "allowed_tools": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "$defs": {
    "executionMode": {
      "type": "string",
      "enum": ["claude-local", "local-file", "local-script", "local-rag", "mcp", "remote-api"]
    },
    "inputField": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "text",
            "markdown",
            "number",
            "boolean",
            "select",
            "multi_select",
            "file",
            "files",
            "directory",
            "json",
            "yaml",
            "table",
            "persona",
            "longform_ref"
          ]
        },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "required": { "type": "boolean", "default": false },
        "multiple": { "type": "boolean", "default": false },
        "default_value": {},
        "min_length": { "type": "integer", "minimum": 0 },
        "max_length": { "type": "integer", "minimum": 1 },
        "accept": { "type": "array", "items": { "type": "string" } },
        "options": { "type": "array", "items": { "type": "string" } },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["title", "value"],
            "additionalProperties": false,
            "properties": {
              "title": { "type": "string" },
              "value": { "type": "string" }
            }
          }
        },
        "min_files": {
          "type": "integer",
          "minimum": 0,
          "description": "Minimum number of files for 'files' type."
        },
        "max_files": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum number of files for 'files' type."
        },
        "columns": {
          "type": "array",
          "description": "Column definitions for 'table' type.",
          "items": {
            "type": "object",
            "required": ["name"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "type": { "type": "string", "enum": ["string", "number", "boolean", "date"] },
              "description": { "type": "string" }
            }
          }
        },
        "schema": {
          "type": "object",
          "description": "Inline JSON Schema for 'json' type inputs.",
          "additionalProperties": true
        }
      }
    }
  }
}
